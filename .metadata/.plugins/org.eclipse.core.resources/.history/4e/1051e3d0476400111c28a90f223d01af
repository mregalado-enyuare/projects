/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MPU Configuration--------------------------------------------------------*/
  MPU_Config();

  /* MCU Configuration--------------------------------------------------------*/
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_I2C1_Init();
  MX_USART3_UART_Init();

  /* USER CODE BEGIN 2 */
  HAL_Delay(1000);
  Serial_Print("Starting...\r\n");

  dev->IO.Address  = 0x52;
  dev->IO.WriteReg = I2C_WriteReg;
  dev->IO.ReadReg  = I2C_ReadReg;
  dev->IO.GetTick  = GetTick;
  dev->IO.Init     = NULL;
  dev->IO.DeInit   = NULL;

  // Init sensor
  sensorStatus = VL53L4CD_SensorInit(dev);
  if (sensorStatus != 0)
  {
    Serial_Print("InitSensor() failed\r\n");
    while (1);
  }

  // Set timing (50ms budget, 0ms inter-measurement)
  VL53L4CD_SetRangeTiming(dev, 50, 0);

  // Start ranging
  sensorStatus = VL53L4CD_StartRanging(dev);
  if (sensorStatus != 0)
  {
    Serial_Print("StartRanging failed\r\n");
    while (1);
  }

  Serial_Print("Sensor ready!\r\n");
  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    if (VL53L4CD_CheckForDataReady(dev, &dataReady) == 0 && dataReady)
    {
      if (VL53L4CD_GetResult(dev, &results) == 0)
      {
        distance = results.distance_mm;
        snprintf(uartBuf, sizeof(uartBuf), "Distance: %u mm\r\n", distance);
        Serial_Print(uartBuf);
      }
      VL53L4CD_ClearInterrupt(dev);
    }
    HAL_Delay(50);
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

