	/***************************************************************************************************************/
	/*                                          Distance Sensor                                                    */
	/***************************************************************************************************************/

	void Distance_Init(void)
	{
	    VL53L4CD_Error vst = VL53L4CD_Init(&hi2c3);
	    if (vst != VL53L4CD_OK) {
	        char msg[48];
	        int  n = snprintf(msg, sizeof(msg), "VL53L4CD init failed: %d\r\n", vst);
	        HAL_UART_Transmit(&huart3, (uint8_t *)msg, (uint16_t)n, HAL_MAX_DELAY);
	        return;
	    }
	    VL53L4CD_StartRanging(&hi2c3);
	    HAL_UART_Transmit(&huart3, (uint8_t *)"VL53L4CD ready\r\n", 16, HAL_MAX_DELAY);
	}

	void Distance_Poll(void)
	{
	    static uint32_t last_print_ms = 0;

	    uint8_t ready = 0;
	    VL53L4CD_CheckForDataReady(&hi2c3, &ready);
	    if (!ready) return;

	    VL53L4CD_Result_t res;
	    VL53L4CD_GetResult(&hi2c3, &res);
	    VL53L4CD_ClearInterrupt(&hi2c3);

	    if (res.range_status == 0) {
	        g_distance_mm    = res.distance_mm;
	        g_distance_valid = 1;
	    } else {
	        g_distance_valid = 0;
	    }

	    uint32_t now = HAL_GetTick();
	    if ((now - last_print_ms) >= DISTANCE_PRINT_INTERVAL_MS) {
	        last_print_ms = now;
	        char msg[48];
	        int  n;
	        if (g_distance_valid)
	            n = snprintf(msg, sizeof(msg), "Dist: %u mm\r\n", g_distance_mm);
	        else
	            n = snprintf(msg, sizeof(msg), "Dist: err (status=%u)\r\n", res.range_status);
	        HAL_UART_Transmit(&huart3, (uint8_t *)msg, (uint16_t)n, HAL_MAX_DELAY);
	    }
	}

