	/***************************************************************************************************************/
	/*                                           DC Motor + Encoder                                                */
	/***************************************************************************************************************/

	void UpdateEncoderPosition(void) {
	  uint16_t cur = __HAL_TIM_GET_COUNTER(&htim1);
	  int16_t delta = (int16_t)(cur - last_encoder_reading);
	  extended_position += delta;
	  last_encoder_reading = cur;
	}

	static inline void TIM15_SetDutyPct(uint32_t pct) {
	  if (pct > 100U) pct = 100U;
	  uint32_t arr = __HAL_TIM_GET_AUTORELOAD(&htim15);
	  uint32_t ccr = ((uint64_t)(arr + 1U) * pct) / 100U;
	  if (ccr > arr) ccr = arr;
	  __HAL_TIM_SET_COMPARE(&htim15, TIM_CHANNEL_1, ccr);
	}

	#define SYRINGE_RAMP_PCT   (45U)
	#define SYRINGE_MIN_DUTY   (25U)

	static inline uint32_t clamp_u32(uint32_t v, uint32_t lo, uint32_t hi) {
	  if (v < lo) return lo;
	  if (v > hi) return hi;
	  return v;
	}

	static inline uint32_t ramp_from_remaining(uint32_t max_duty, uint32_t min_duty,
											  uint32_t remain, uint32_t ramp_steps)
	{
	  if (ramp_steps == 0U) return max_duty;
	  if (remain >= ramp_steps) return max_duty;
	  uint32_t duty = min_duty + (uint32_t)(((uint64_t)(max_duty - min_duty) * remain) / ramp_steps);
	  if (duty < min_duty) duty = min_duty;
	  return duty;
	}

	#define SYRINGE_NO_ENCODER_TIMEOUT_MS  1000U

	static inline void syringe_abort_outputs(void)
	{
	  HAL_TIM_PWM_Stop(&htim15, TIM_CHANNEL_1);
	  TIM15_SetDutyPct(0);
	  HAL_GPIO_WritePin(SYRINGE_IN1_GPIO_Port, SYRINGE_IN1_Pin, GPIO_PIN_RESET);
	  HAL_GPIO_WritePin(SYRINGE_IN2_GPIO_Port, SYRINGE_IN2_Pin, GPIO_PIN_RESET);
	}

	bool moveForward(uint32_t move_value, uint32_t retract_pct)
	{
	  if (move_value == 0) return true;

	  UpdateEncoderPosition();
	  int32_t start_pos = extended_position;
	  int32_t target    = start_pos - (int32_t)move_value;

	  uint32_t ramp_pct  = clamp_u32(SYRINGE_RAMP_PCT, 0U, 50U);
	  uint32_t min_duty  = clamp_u32(SYRINGE_MIN_DUTY, 0U, 100U);
	  retract_pct        = clamp_u32(retract_pct, 0U, 100U);
	  if (retract_pct < min_duty) retract_pct = min_duty;

	  uint32_t ramp_steps = (move_value * ramp_pct) / 100U;
	  if ((2U * ramp_steps) > move_value) ramp_steps = move_value / 2U;

	  HAL_GPIO_WritePin(SYRINGE_IN1_GPIO_Port, SYRINGE_IN1_Pin, GPIO_PIN_SET);
	  HAL_GPIO_WritePin(SYRINGE_IN2_GPIO_Port, SYRINGE_IN2_Pin, GPIO_PIN_RESET);
	  HAL_TIM_PWM_Start(&htim15, TIM_CHANNEL_1);

	  uint32_t last_change_ms = HAL_GetTick();
	  int32_t  last_pos       = extended_position;

	  while (1) {
	    UpdateEncoderPosition();
	    if (extended_position != last_pos) {
	      last_pos = extended_position;
	      last_change_ms = HAL_GetTick();
	    } else {
	      if ((HAL_GetTick() - last_change_ms) > SYRINGE_NO_ENCODER_TIMEOUT_MS) {
	        snprintf(s_stall_msg, sizeof(s_stall_msg),
	                 "rack=%d motor=%d DOWN: start=%ld target=%ld pos=%ld",
	                 s_stall_rack, s_stall_motor,
	                 (long)start_pos, (long)target, (long)extended_position);
	        printf("ERROR: Syringe encoder stalled (%s)\r\n", s_stall_msg);
	        syringe_abort_outputs();
	        return false;
	      }
	    }
	    int32_t err = extended_position - target;
	    if (err <= 0) break;

	    uint32_t remain = (uint32_t)err;
	    uint32_t moved  = (uint32_t)(start_pos - extended_position);
	    uint32_t duty;
	    if (ramp_steps != 0U && moved < ramp_steps)
	      duty = min_duty + (uint32_t)(((uint64_t)(retract_pct - min_duty) * moved) / ramp_steps);
	    else
	      duty = ramp_from_remaining(retract_pct, min_duty, remain, ramp_steps);

	    TIM15_SetDutyPct(duty);
	  }

	  syringe_abort_outputs();
	  printf("Target: %ld, Actual: %ld\r\n", (long)target, (long)extended_position);
	  return true;
	}

	bool moveBackward(uint32_t move_value, uint32_t speed_pct)
	{
	  if (move_value == 0) return true;

	  UpdateEncoderPosition();
	  int32_t start_pos = extended_position;
	  int32_t target    = start_pos + (int32_t)move_value;

	  uint32_t ramp_pct = clamp_u32(SYRINGE_RAMP_PCT, 0U, 50U);
	  uint32_t min_duty = clamp_u32(SYRINGE_MIN_DUTY, 0U, 100U);
	  speed_pct         = clamp_u32(speed_pct, 0U, 100U);
	  if (speed_pct < min_duty) speed_pct = min_duty;

	  uint32_t ramp_steps = (move_value * ramp_pct) / 100U;
	  if ((2U * ramp_steps) > move_value) ramp_steps = move_value / 2U;

	  HAL_GPIO_WritePin(SYRINGE_IN1_GPIO_Port, SYRINGE_IN1_Pin, GPIO_PIN_RESET);
	  HAL_GPIO_WritePin(SYRINGE_IN2_GPIO_Port, SYRINGE_IN2_Pin, GPIO_PIN_SET);
	  HAL_TIM_PWM_Start(&htim15, TIM_CHANNEL_1);

	  uint32_t last_change_ms = HAL_GetTick();
	  int32_t  last_pos       = extended_position;

	  while (1) {
	    UpdateEncoderPosition();
	    if (extended_position != last_pos) {
	      last_pos = extended_position;
	      last_change_ms = HAL_GetTick();
	    } else {
	      if ((HAL_GetTick() - last_change_ms) > SYRINGE_NO_ENCODER_TIMEOUT_MS) {
	        snprintf(s_stall_msg, sizeof(s_stall_msg),
	                 "rack=%d motor=%d UP: start=%ld target=%ld pos=%ld",
	                 s_stall_rack, s_stall_motor,
	                 (long)start_pos, (long)target, (long)extended_position);
	        printf("ERROR: Syringe encoder stalled (%s)\r\n", s_stall_msg);
	        syringe_abort_outputs();
	        return false;
	      }
	    }
	    int32_t err = target - extended_position;
	    if (err <= 0) break;

	    uint32_t remain = (uint32_t)err;
	    uint32_t moved  = (uint32_t)(extended_position - start_pos);
	    uint32_t duty;
	    if (ramp_steps != 0U && moved < ramp_steps)
	      duty = min_duty + (uint32_t)(((uint64_t)(speed_pct - min_duty) * moved) / ramp_steps);
	    else
	      duty = ramp_from_remaining(speed_pct, min_duty, remain, ramp_steps);

	    TIM15_SetDutyPct(duty);
	  }

	  syringe_abort_outputs();
	  return true;
	}

	static void send_gratuitous_arp(void *arg) {
	  struct netif *netif = (struct netif*) arg;
	  etharp_gratuitous(netif);
	  sys_timeout(GRATUITOUS_ARP_INTERVAL_MS, send_gratuitous_arp, netif);
	}

