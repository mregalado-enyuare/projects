	  if (huart->Instance == USART3)    // checks if uart3 is initalized
	  {
		if (temp != '\r')   // ensures that the bit '\r' is never saved
			{
		  if (indx < sizeof(terminalInput) - 1)   //
			  {
			terminalInput[indx++] = temp;
		  }
		} else {
		  terminalInput[indx] = '\0';   // sets index to null terminal
		  indx = 0;

		  commandReceived = true;
		}

		HAL_UART_Receive_IT(&huart3, &temp, 1);
	  }
	}

