/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */
	  __disable_irq();
	  __DSB();
	  __ISB();

	  /* Invalidate by set/way: no writeback, so no bus access */
	  SCB_InvalidateDCache();

	  /* Manually disable D-cache without trying to clean it */
	  SCB->CCR &= ~SCB_CCR_DC_Msk;
	  __DSB();
	  __ISB();

	  __enable_irq();

	  HAL_NVIC_SetPriority(SysTick_IRQn, 0, 0);

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */
  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */
  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_USART3_UART_Init();
  MX_USB_OTG_HS_USB_Init();
  MX_TIM2_Init();
  MX_TIM3_Init();
  MX_TIM1_Init();
  MX_LWIP_Init();
  MX_TIM23_Init();
  MX_TIM15_Init();
  MX_TIM24_Init();
  MX_IWDG1_Init();
  MX_TIM5_Init();
  MX_TIM4_Init();
  MX_TIM12_Init();
  MX_TIM8_Init();
  MX_I2C3_Init();
  /* USER CODE BEGIN 2 */

	  lid_motors_init();
	  ice_dispenser_init();

	  // Read DIP Switches (pull-ups: ON=closed=GND->0, OFF=open->1)
	  uint8_t dip1 = (HAL_GPIO_ReadPin(DIP_1_GPIO_Port, DIP_1_Pin) == GPIO_PIN_RESET) ? 0 : 1;
	  uint8_t dip2 = (HAL_GPIO_ReadPin(DIP_2_GPIO_Port, DIP_2_Pin) == GPIO_PIN_RESET) ? 0 : 1;
	  uint8_t dip3 = (HAL_GPIO_ReadPin(DIP_3_GPIO_Port, DIP_3_Pin) == GPIO_PIN_RESET) ? 0 : 1;
	  uint8_t dip4 = (HAL_GPIO_ReadPin(DIP_4_GPIO_Port, DIP_4_Pin) == GPIO_PIN_RESET) ? 0 : 1;

	  // print DIP switch states for debugging
	  char msg[64];
	  int n = snprintf(msg, sizeof(msg),
					   "DIP1:%u DIP2:%u DIP3:%u DIP4:%u\r\n",
					   dip1, dip2, dip3, dip4);
	  if (n > 0) HAL_UART_Transmit(&huart3, (uint8_t*)msg, (uint16_t)n, HAL_MAX_DELAY);

	  // DIP1/DIP2 select 0..3 (101..104)
	  uint8_t dip_value = (dip1 << 1) | dip2;     // 0..3
	  uint8_t bank_on   = (dip3 == 0) ? 1 : 0;    // DIP3 ON => 1
	  uint8_t board_id  = (uint8_t)(dip_value + 1 + (bank_on * 5));  // 1..4 or 6..9

	  // Ethernet Setup
	  udp_server_init(board_id);

	  if (HAL_ETH_Start(&heth) != HAL_OK) {
		Error_Handler();
	  }

	  /* give the PHY a moment to negotiate */
	  HAL_Delay(1000);

	  // setup periodic gratuitous ARP
	  sys_timeout(GRATUITOUS_ARP_INTERVAL_MS, send_gratuitous_arp, netif_default);

	  //send one ARP
	  etharp_gratuitous(netif_default);

	  /* print link status once on startup */
	  //  PrintEthLinkStatus();
	  char ipstr[32];
	  ip4addr_ntoa_r(&netif_default->ip_addr, ipstr, sizeof(ipstr));
	  HAL_UART_Transmit(&huart3, (uint8_t*) "My IP: ", 7, HAL_MAX_DELAY);
	  HAL_UART_Transmit(&huart3, (uint8_t*) ipstr, strlen(ipstr), HAL_MAX_DELAY);
	  HAL_UART_Transmit(&huart3, (uint8_t*) "\r\n", 2, HAL_MAX_DELAY);

	  // directly calling uart config
	  __enable_irq();
	  HAL_NVIC_SetPriority(USART3_IRQn, 1, 0);
	  HAL_NVIC_EnableIRQ(USART3_IRQn);

	  HAL_UART_Receive_IT(&huart3, &temp, 1);

	  HAL_TIM_Encoder_Start(&htim1, TIM_CHANNEL_ALL);

	  /* Initialize extended position right after starting the encoder */
	  last_encoder_reading = 0;
	  extended_position = 0;

	  counter = __HAL_TIM_GET_COUNTER(&htim1); // initialize encoder counter

	  // Enable 24V motors on boot
	  HAL_GPIO_WritePin(ENABLE_24V_GPIO_Port, ENABLE_24V_Pin, GPIO_PIN_SET);

	  /* I2C3 diagnostics (PA8=SCL, PC9=SDA on CN12) */
	  {
		  char smsg[64];
		  int sn;

		  /* 1. Print I2C3 state and error code */
		  sn = snprintf(smsg, sizeof(smsg), "I2C3 state=0x%02X err=0x%08lX\r\n",
				  (unsigned)hi2c3.State, hi2c3.ErrorCode);
		  HAL_UART_Transmit(&huart3, (uint8_t*)smsg, (uint16_t)sn, HAL_MAX_DELAY);

		  /* 2. Try VL53L4CD address 0x29 directly with long timeout */
		  HAL_StatusTypeDef hst = HAL_I2C_IsDeviceReady(&hi2c3, 0x29 << 1, 3, 100);
		  sn = snprintf(smsg, sizeof(smsg), "0x29 probe: %s (state=0x%02X err=0x%08lX)\r\n",
				  hst == HAL_OK ? "ACK" :
				  hst == HAL_BUSY ? "BUSY" :
				  hst == HAL_TIMEOUT ? "TIMEOUT" : "ERROR",
				  (unsigned)hi2c3.State, hi2c3.ErrorCode);
		  HAL_UART_Transmit(&huart3, (uint8_t*)smsg, (uint16_t)sn, HAL_MAX_DELAY);

		  /* 3. Full scan — print every non-timeout response */
		  HAL_UART_Transmit(&huart3, (uint8_t*)"Scanning I2C3...\r\n", 18, HAL_MAX_DELAY);
		  int found = 0;
		  for (uint8_t addr = 1; addr < 128; addr++) {
			  HAL_StatusTypeDef r = HAL_I2C_IsDeviceReady(&hi2c3, (uint16_t)(addr << 1), 2, 50);
			  if (r == HAL_OK) {
				  sn = snprintf(smsg, sizeof(smsg), "  ACK  at 0x%02X\r\n", addr);
				  HAL_UART_Transmit(&huart3, (uint8_t*)smsg, (uint16_t)sn, HAL_MAX_DELAY);
				  found = 1;
			  } else if (r == HAL_ERROR) {
				  /* Device present but NACKing — print it */
				  sn = snprintf(smsg, sizeof(smsg), "  NACK at 0x%02X (err=0x%08lX)\r\n",
						  addr, hi2c3.ErrorCode);
				  HAL_UART_Transmit(&huart3, (uint8_t*)smsg, (uint16_t)sn, HAL_MAX_DELAY);
			  }
			  /* HAL_TIMEOUT = nothing on bus, skip */
		  }
		  if (!found)
			  HAL_UART_Transmit(&huart3, (uint8_t*)"  No ACK found\r\n", 16, HAL_MAX_DELAY);
	  }

	  /* VL53L4CD distance sensor init */
	  {
		  char vmsg[64];
		  VL53L4CD_Error vst = VL53L4CD_Init(&hi2c3);
		  if (vst != VL53L4CD_OK) {
			  int vn = snprintf(vmsg, sizeof(vmsg), "VL53L4CD init failed: %d\r\n", vst);
			  HAL_UART_Transmit(&huart3, (uint8_t*)vmsg, (uint16_t)vn, HAL_MAX_DELAY);
		  } else {
			  VL53L4CD_StartRanging(&hi2c3);
			  HAL_UART_Transmit(&huart3, (uint8_t*)"VL53L4CD ready\r\n", 16, HAL_MAX_DELAY);
		  }
	  }

  /* USER CODE END 2 */

  /* Initialize leds */
  BSP_LED_Init(LED_GREEN);

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
	  MX_LWIP_Process(); // required for UDP receive + lwIP timers in bare-metal
	  udp_async_pump(); // drains async_bus -> sends DONE/ERR to last peer
	  GotoSeq_Pump(); // progresses multi-segment gantry moves
	  HomingX_Pump(); // progresses X homing / independent / until limit
	  CalibrateDual_Pump();
	  LidCal_Pump(); // advances lid motor calibration state machine
	  udp_log_process(); // optional but helps not block log queue
	  HAL_IWDG_Refresh(&hiwdg1); // if enabled
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
	  {
		  uint8_t ready = 0;
		  VL53L4CD_CheckForDataReady(&hi2c3, &ready);
		  if (ready) {
			  VL53L4CD_Result_t vres;
			  VL53L4CD_GetResult(&hi2c3, &vres);
			  VL53L4CD_ClearInterrupt(&hi2c3);
			  if (vres.range_status == 0) {
				  g_distance_mm = vres.distance_mm;
				  char dmsg[48];
				  int dn = snprintf(dmsg, sizeof(dmsg), "Dist: %u mm\r\n", vres.distance_mm);
				  HAL_UART_Transmit(&huart3, (uint8_t*)dmsg, (uint16_t)dn, HAL_MAX_DELAY);
			  }
		  }
	  }
  }
  /* USER CODE END 3 */
}

