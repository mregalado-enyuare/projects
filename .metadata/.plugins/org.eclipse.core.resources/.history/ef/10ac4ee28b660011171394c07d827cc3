/* uart_handler.c
 * Handles UART receive from Arduino (USART2)
 * and debug output (also USART2)
 */

#include "uart_handler.h"
#include <stdio.h>
#include <string.h>

// ── Private Variables ───────────────────────────
static char    rxBuffer[RX_BUFFER_SIZE];
static uint8_t rxByte;
static uint8_t rxIndex   = 0;
static bool    dataReady = false;

// ── Public Functions ────────────────────────────

void UART_Init(void) {
    // Start interrupt-driven receive on USART2
    HAL_UART_Receive_IT(&huart2, &rxByte, 1);
}

void UART_ReceiveIT(void) {
    if (rxByte == '\n') {
        rxBuffer[rxIndex] = '\0';  // null terminate
        rxIndex   = 0;
        dataReady = true;
    } else {
        if (rxIndex < RX_BUFFER_SIZE - 1) {
            rxBuffer[rxIndex++] = rxByte;
        }
    }
    // Re-arm interrupt for next byte
    HAL_UART_Receive_IT(&huart2, &rxByte, 1);
}

void UART_ParseBuffer(char* buffer, SensorReading_t* reading) {
    // Expects format: "DIST:142,STATUS:0"
    int parsed = sscanf(buffer,
                        "DIST:%hu,STATUS:%hhu",
                        &reading->distanceMm,
                        &reading->rangeStatus);
    reading->isValid = (parsed == 2);
}

void UART_DebugPrint(SensorReading_t* reading) {
    char msg[64];
    snprintf(msg, sizeof(msg),
             "[H723ZG] Distance: %u mm | Status: %u\r\n",
             reading->distanceMm,
             reading->rangeStatus);
    HAL_UART_Transmit(&huart2,
                      (uint8_t*)msg,
                      strlen(msg),
                      HAL_MAX_DELAY);
}

bool  UART_IsDataReady(void)    { return dataReady; }
void  UART_ClearDataReady(void) { dataReady = false; }
char* UART_GetBuffer(void)      { return rxBuffer; }
