#include "main.h"

/* USER CODE BEGIN Includes */
#include "vl53l4cd.h"
/* USER CODE END Includes */

I2C_HandleTypeDef hi2c1;

/* USER CODE BEGIN PV */
volatile uint16_t g_distance_mm        = 0;
volatile uint8_t  g_sensor_init_status = 99;
volatile uint8_t  g_i2c_probe_result   = 99;
volatile uint32_t g_ready_count        = 0;
volatile uint8_t  g_last_range_status  = 99;
volatile uint8_t  g_fw_status          = 99;
/* USER CODE END PV */

void SystemClock_Config(void);
static void MPU_Config(void);
static void MX_GPIO_Init(void);
static void MX_I2C1_Init(void);

int main(void)
{
  /* USER CODE BEGIN 1 */
  /* USER CODE END 1 */

  MPU_Config();
  HAL_Init();
  SystemClock_Config();
  MX_GPIO_Init();
  MX_I2C1_Init();

  /* USER CODE BEGIN 2 */
  HAL_Delay(2000);

  /* I2C probe */
  HAL_StatusTypeDef probe = HAL_I2C_IsDeviceReady(&hi2c1, 0x29 << 1, 3, 100);
  g_i2c_probe_result = (uint8_t)probe;

  /* Read firmware boot register */
  uint8_t fw = 0;
  HAL_I2C_Mem_Read(&hi2c1, 0x52, 0x00E5, I2C_MEMADD_SIZE_16BIT, &fw, 1, 100);
  g_fw_status = fw;

  /* VL53L4CD init */
  VL53L4CD_Error vst = VL53L4CD_Init(&hi2c1);
  g_sensor_init_status = (uint8_t)vst;

  /* Start ranging */
  VL53L4CD_StartRanging(&hi2c1);
  HAL_Delay(500);  /* let sensor stabilize */

  /* USER CODE END 2 */

  while (1)
  {
    /* USER CODE BEGIN 3 */
    {
      uint8_t ready = 0;
      VL53L4CD_CheckForDataReady(&hi2c1, &ready);
      if (ready) {
        g_ready_count++;
        VL53L4CD_Result_t vres;
        VL53L4CD_GetResult(&hi2c1, &vres);
        VL53L4CD_ClearInterrupt(&hi2c1);
        g_last_range_status = vres.range_status;
        if (vres.range_status == 0) {
          g_distance_mm = vres.distance_mm;
        }
      }
    }
    HAL_Delay(10);
    /* USER CODE END 3 */
  }
}

