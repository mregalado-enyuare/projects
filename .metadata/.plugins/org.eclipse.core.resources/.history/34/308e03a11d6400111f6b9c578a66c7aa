#include "platform.h"
#include "i2c.h"

#define TIMEOUT 100

uint8_t VL53L4CD_RdByte(Dev_t dev, uint16_t RegisterAdress, uint8_t *value)
{
    uint8_t reg[2] = { RegisterAdress >> 8, RegisterAdress & 0xFF };
    if (HAL_I2C_Master_Transmit(&hi2c1, dev, reg, 2, TIMEOUT) != HAL_OK)
        return 255;
    if (HAL_I2C_Master_Receive(&hi2c1, dev, value, 1, TIMEOUT) != HAL_OK)
        return 255;
    return 0;
}

uint8_t VL53L4CD_RdWord(Dev_t dev, uint16_t RegisterAdress, uint16_t *value)
{
    uint8_t reg[2] = { RegisterAdress >> 8, RegisterAdress & 0xFF };
    uint8_t buf[2];
    if (HAL_I2C_Master_Transmit(&hi2c1, dev, reg, 2, TIMEOUT) != HAL_OK)
        return 255;
    if (HAL_I2C_Master_Receive(&hi2c1, dev, buf, 2, TIMEOUT) != HAL_OK)
        return 255;
    *value = (uint16_t)(buf[0] << 8) | buf[1];
    return 0;
}

uint8_t VL53L4CD_RdDWord(Dev_t dev, uint16_t RegisterAdress, uint32_t *value)
{
    uint8_t reg[2] = { RegisterAdress >> 8, RegisterAdress & 0xFF };
    uint8_t buf[4];
    if (HAL_I2C_Master_Transmit(&hi2c1, dev, reg, 2, TIMEOUT) != HAL_OK)
        return 255;
    if (HAL_I2C_Master_Receive(&hi2c1, dev, buf, 4, TIMEOUT) != HAL_OK)
        return 255;
    *value = (uint32_t)(buf[0] << 24) | (buf[1] << 16) | (buf[2] << 8) | buf[3];
    return 0;
}

uint8_t VL53L4CD_WrByte(Dev_t dev, uint16_t RegisterAdress, uint8_t value)
{
    uint8_t buf[3] = { RegisterAdress >> 8, RegisterAdress & 0xFF, value };
    if (HAL_I2C_Master_Transmit(&hi2c1, dev, buf, 3, TIMEOUT) != HAL_OK)
        return 255;
    return 0;
}

uint8_t VL53L4CD_WrWord(Dev_t dev, uint16_t RegisterAdress, uint16_t value)
{
    uint8_t buf[4] = { RegisterAdress >> 8, RegisterAdress & 0xFF,
                       value >> 8, value & 0xFF };
    if (HAL_I2C_Master_Transmit(&hi2c1, dev, buf, 4, TIMEOUT) != HAL_OK)
        return 255;
    return 0;
}

uint8_t VL53L4CD_WrDWord(Dev_t dev, uint16_t RegisterAdress, uint32_t value)
{
    uint8_t buf[6] = { RegisterAdress >> 8, RegisterAdress & 0xFF,
                       (value >> 24) & 0xFF, (value >> 16) & 0xFF,
                       (value >> 8) & 0xFF, value & 0xFF };
    if (HAL_I2C_Master_Transmit(&hi2c1, dev, buf, 6, TIMEOUT) != HAL_OK)
        return 255;
    return 0;
}

uint8_t WaitMs(Dev_t dev, uint32_t TimeMs)
{
    HAL_Delay(TimeMs);
    return 0;
}
